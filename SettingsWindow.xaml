<Window x:Class="TeamsAudioCapture.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:properties="clr-namespace:TeamsAudioCapture.Properties"
        Title="Settings" Height="500" Width="550"
        Background="#F5F5F5"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="#2196F3"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1976D2"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="⚙️ Settings" FontSize="20" FontWeight="Bold" Foreground="#333"/>
            <TextBlock Text="{x:Static properties:Resources.SettingsSubtitleLiveApi}" Foreground="#666" FontSize="12" Margin="0,5,0,0"/>
        </StackPanel>
        
        <!-- Settings Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Model Selection Section -->
                <Border Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,10"
                        BorderThickness="1" BorderBrush="#E0E0E0">
                    <StackPanel>
                        <TextBlock Text="Model Selection" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>

                        <TextBlock Text="Transcription Provider" FontWeight="Bold" Margin="0,0,0,5"/>
                        <ComboBox x:Name="TranscriptionProviderComboBox" Padding="6" Margin="0,0,0,10"/>

                        <TextBlock Text="Q/A Model" FontWeight="Bold" Margin="0,0,0,5"/>
                        <ComboBox x:Name="QAModelComboBox" Padding="6" Margin="0,0,0,10"/>

                        <TextBlock TextWrapping="Wrap" Foreground="#666" FontSize="11">
                            Choose model entries from configuration. Keys are managed separately in local settings.
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- API Keys Section -->
                <Border Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,10"
                        BorderThickness="1" BorderBrush="#E0E0E0">
                    <StackPanel>
                        <TextBlock Text="API Keys" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>

                        <TextBlock Text="Deepgram API Key" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBox x:Name="DeepgramApiKeyTextBox"
                                 Padding="8"
                                 FontFamily="Consolas"
                                 FontSize="12"
                                 Margin="0,0,0,10"/>

                        <TextBlock Text="Gemini API Key" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBox x:Name="ApiKeyTextBox" 
                                 Padding="8"
                                 FontFamily="Consolas"
                                 FontSize="12"
                                 Margin="0,0,0,10"/>

                        <TextBlock Text="OpenAI API Key" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBox x:Name="OpenAiApiKeyTextBox" 
                                 Padding="8"
                                 FontFamily="Consolas"
                                 FontSize="12"
                                 Margin="0,0,0,10"/>

                        <TextBlock Text="Claude API Key" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBox x:Name="ClaudeApiKeyTextBox"
                                 Padding="8"
                                 FontFamily="Consolas"
                                 FontSize="12"
                                 Margin="0,0,0,10"/>

                        <TextBlock Text="Mercury API Key" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBox x:Name="MercuryApiKeyTextBox"
                                 Padding="8"
                                 FontFamily="Consolas"
                                 FontSize="12"
                                 Margin="0,0,0,10"/>

                        <TextBlock TextWrapping="Wrap" Foreground="#666" FontSize="11" Margin="0,0,0,8">
                            Keep this file out of source control. Use provider dashboards to generate keys.
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Recording Mode Section -->
                <Border Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,10"
                        BorderThickness="1" BorderBrush="#E0E0E0">
                    <StackPanel>
                        <TextBlock Text="🎙️ Recording Mode" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>

                        <CheckBox x:Name="SaveAudioCheckBox" Content="Save audio files to disk" 
                                  IsChecked="True" Margin="0,5,0,5" FontSize="13"/>
                        <CheckBox x:Name="CaptureMicrophoneCheckBox" Content="Capture microphone (your voice)" 
                                  Margin="0,5,0,5" FontSize="13"/>
                        <CheckBox x:Name="ProcessWithGeminiCheckBox" Content="{x:Static properties:Resources.SettingsProcessWithLiveApi}" 
                                  Margin="0,5,0,5" FontSize="13"/>
                        <CheckBox x:Name="ShowTranscriptCheckBox" Content="Show transcript in main window" 
                                  Margin="0,5,0,5" FontSize="13"/>

                        <TextBlock TextWrapping="Wrap" Foreground="#999" FontSize="11" Margin="0,10,0,0">
                            System audio (Teams/speakers) is always captured. Enable microphone to include your voice.
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Audio Save Location Section -->
                <Border Background="White" CornerRadius="8" Padding="15"
                        BorderThickness="1" BorderBrush="#E0E0E0">
                    <StackPanel>
                        <TextBlock Text="📁 Audio Save Location" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>

                        <TextBlock Text="Save recordings to:" FontWeight="Bold" Margin="0,0,0,5"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="SaveLocationTextBox" 
                                     Grid.Column="0"
                                     Padding="8"
                                     FontSize="12"
                                     Margin="0,0,10,0"
                                     IsReadOnly="True"/>
                            <Button Grid.Column="1" 
                                    Content="Browse..." 
                                    Click="BrowseButton_Click"
                                    Padding="15,8"
                                    Background="#607D8B"/>
                        </Grid>

                        <TextBlock TextWrapping="Wrap" Foreground="#999" FontSize="11" Margin="0,10,0,0">
                            Leave empty to use Desktop folder (default).
                        </TextBlock>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
        
        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Cancel" Click="CancelButton_Click" Background="#999" Width="100"/>
            <Button Content="Save" Click="SaveButton_Click" Width="100"/>
        </StackPanel>
    </Grid>
</Window>
